{
  "name": "@gijun-ai/server",
  "version": "0.1.0",
  "description": "REST API server for the personal AI agent governance platform",
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "build": "tsc",
    "dev": "node --watch --import=tsx/esm src/server.ts",
    "start": "node dist/server.js",
    "test": "tsc -p tsconfig.test.json && node --test 'dist-test/__tests__/*.test.js'"
  },
  "dependencies": {
    "@gijun-ai/core": "workspace:*",
    "express": "^5.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^25.6.0",
    "tsx": "^4.19.4",
    "typescript": "^6.0.3"
  }
}
