{
  "name": "@gijun-ai/mcp-server",
  "version": "0.1.0",
  "description": "MCP server for personal AI agent governance platform",
  "type": "module",
  "bin": {
    "agentguard-mcp": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc",
    "dev": "node --import=tsx/esm src/index.ts",
    "start:stdio": "node --import=tsx/esm src/index.ts",
    "start:http": "AGENTGUARD_MCP_TRANSPORT=http node --import=tsx/esm src/index.ts"
  },
  "dependencies": {
    "@gijun-ai/core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.11.4",
    "express": "^5.1.0",
    "zod": "^3.24.3",
    "zod-to-json-schema": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^22.15.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
