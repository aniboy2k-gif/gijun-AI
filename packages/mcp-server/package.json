{
  "name": "@gijun-ai/mcp-server",
  "version": "0.2.0",
  "description": "MCP server for personal single-user AI agent audit/verification workbench",
  "type": "module",
  "bin": {
    "agentguard-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepack": "tsc && chmod +x dist/index.js",
    "dev": "node --import=tsx/esm src/index.ts",
    "start:stdio": "node dist/index.js",
    "dev:stdio": "node --import=tsx/esm src/index.ts",
    "start:http": "AGENTGUARD_MCP_TRANSPORT=http node dist/index.js",
    "dev:http": "AGENTGUARD_MCP_TRANSPORT=http node --import=tsx/esm src/index.ts",
    "test": "tsc -p tsconfig.test.json && node --test 'dist-test/__tests__/*.test.js'"
  },
  "dependencies": {
    "@gijun-ai/core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.11.4",
    "express": "^5.1.0",
    "zod": "^3.24.3",
    "zod-to-json-schema": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^22.15.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
