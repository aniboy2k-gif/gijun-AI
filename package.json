{
  "name": "gijun-ai",
  "version": "0.1.0",
  "description": "Personal AI Agent Governance Workbench — 기준을 세우고, 검증하며, 학습한다",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @gijun-ai/server dev",
    "init": "node --import=tsx/esm packages/core/src/cli/init.ts",
    "audit:verify": "node --input-type=module -e \"import { runVerifyChainCli } from '@gijun-ai/core'; runVerifyChainCli()\"",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "@types/node": "^22.15.3",
    "tsup": "^8.4.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
