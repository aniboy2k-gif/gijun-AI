{
  "name": "gijun-ai",
  "version": "0.1.3",
  "description": "Personal single-user AI agent audit/verification workbench \u2014 \uae30\uc900\uc744 \uc138\uc6b0\uace0, \uac80\uc99d\ud558\uba70, \ud559\uc2b5\ud55c\ub2e4",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @gijun-ai/server dev",
    "init": "node --import=tsx/esm packages/core/src/cli/init.mts",
    "audit:verify": "node --input-type=module -e \"import { runVerifyChainCli } from '@gijun-ai/core'; runVerifyChainCli()\"",
    "lint": "node scripts/lint.mjs check",
    "lint:fix": "node scripts/lint.mjs check --write",
    "sync:readme": "node scripts/sync-readme.mjs",
    "sync:readme:check": "node scripts/sync-readme.mjs --check",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@types/node": "^22.15.3",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@biomejs/biome"
    ]
  }
}
